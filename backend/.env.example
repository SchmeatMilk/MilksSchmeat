# Copy this file to ".env" (same folder) and fill in what you want.
# The app works WITHOUT these keys, but some features will show empty.

# --- Live news headlines ---
# Get a free key from https://newsapi.org/register (takes ~2 minutes)
# Without this: headlines rail shows "Set NEWS_API_KEY to see headlines"
NEWS_API_KEY=

# --- Smarter daily ingestion ---
# If set, the 8:30 AM ingest also uses Claude to extract facts (status, learnings)
# on top of local regex. Only lines that already look fact-bearing are sent to Claude.
# Leave blank to stay 100% local (regex extraction still works perfectly).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Set to "false" to force local-only extraction even with API key present.
INGEST_USE_LLM=

# --- Claude memory location override ---
# The app auto-finds your Claude Desktop memory folder on Windows and Mac.
# If auto-discovery fails, paste the full path to the "memory" folder here.
# Example: CLAUDE_MEMORY_DIR=C:\Users\yourname\AppData\Roaming\Claude\...\memory
# Without this, the app won't see your memory palace files.
CLAUDE_MEMORY_DIR=
