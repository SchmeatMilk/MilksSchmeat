# Copy this file to ".env" (same folder) and fill in what you want.
# The app works WITHOUT any of these — they unlock optional features.

# --- Live news headlines (optional) ---
# Free key from https://newsapi.org/register  (takes ~2 minutes)
NEWS_API_KEY=

# --- Smarter daily ingestion (optional) ---
# If set, the 8:30 AM job ALSO uses Claude to understand your notes (status,
# learnings, phrasing) on top of the always-on local regex. Only the lines that
# already look fact-bearing are sent to Anthropic — never your whole memory store.
# Leave blank to stay 100% local. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Set to "false" to force local-only even when a key is present.
INGEST_USE_LLM=

# --- Claude memory location override (optional) ---
# The app auto-finds your Claude Desktop memory folder (Win32 + Microsoft Store
# builds). If auto-discovery misses it, paste the full path to the "memory"
# folder here. Example:
# CLAUDE_MEMORY_DIR=C:\Users\you\AppData\Roaming\Claude\...\spaces\...\memory
CLAUDE_MEMORY_DIR=
